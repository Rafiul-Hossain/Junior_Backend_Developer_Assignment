          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/refresh-access-token", "host": ["{{base_url}}"], "path": ["auth", "refresh-access-token"] },
            "body": {
