              "body": "{\n  \"status\": true,\n  \"message\": \"Produce list fetched\",\n  \"data\": {\n    \"produces\": [\n      {\n        \"id\": \"uuid\",\n        \"name\": \"Organic Tomatoes\",\n        \"price\": \"5.99\",\n        \"category\": \"Vegetables\",\n        \"availableQuantity\": 50,\n        \"certificationStatus\": \"APPROVED\",\n        \"vendor\": { \"farmName\": \"Green Farm 1\", \"farmLocation\": \"Downtown NYC\" }\n      }\n    ],\n    \"pagination\": {\n      \"currentPage\": 1,\n      \"totalPages\": 10,\n      \"totalData\": 100,\n      \"hasNextPage\": true,\n      \"hasPrevPage\": false\n    }\n  }\n}"
