              "path": ["plants", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Plant Tracking (customer) — emits Socket.IO event",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/plants/{{plant_id}}", "host": ["{{base_url}}"], "path": ["plants", "{{plant_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"growthStage\": \"Flowering\",\n  \"healthStatus\": \"Healthy\",\n  \"notes\": \"Blossoms appearing — staking stems.\",\n  \"imageUrl\": \"https://example.com/basil.jpg\"\n}"
            }
          }
        }
      ]
    },
