            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/community", "host": ["{{base_url}}"], "path": ["community"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tips for container composting\",\n  \"postContent\": \"Small-space composting is easy with a sealed container and brown/green layers...\",\n  \"tags\": [\"composting\", \"urban-farming\", \"tips\"]\n}"
            }
          }
        },
        {
          "name": "Delete Post (author or admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/community/{{post_id}}", "host": ["{{base_url}}"], "path": ["community", "{{post_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Plants",
      "item": [
        {
          "name": "Create Plant Tracking (customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.id) pm.collectionVariables.set('plant_id', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/plants", "host": ["{{base_url}}"], "path": ["plants"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalSpaceId\": \"{{rental_space_id}}\",\n  \"plantName\": \"Basil\",\n  \"growthStage\": \"Seedling\",\n  \"healthStatus\": \"Healthy\",\n  \"harvestDate\": \"2026-07-15\",\n  \"notes\": \"Watered daily, placed in direct sun.\"\n}"
            }
          }
        },
        {
          "name": "My Plants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/plants/my?page=1&limit=10",
