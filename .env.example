PORT=5000
NODE_ENV=development

# PostgreSQL - replace with YOUR password
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/urban_farming?schema=public"

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRES=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES=10d

# Email (optional - for OTP)
EMAIL_EXPIRES=900000
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ADDRESS=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your@gmail.com
ADMIN_EMAIL=admin@urbanfarming.com

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
